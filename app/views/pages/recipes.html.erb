<% content_for :og_tags do %>
  <meta property="og:title" content="Ẩm Thực & Công Thức Nấu Ăn - NaChiNaCon">
  <meta property="og:description" content="Tổng hợp công thức các món ăn ngon, dễ nấu cho cả gia đình">
  <meta property="og:type" content="website">
<% end %>

<!-- Header -->
<section class="py-12 md:py-16 px-4 md:px-6 lg:px-8 relative overflow-hidden" style="background: linear-gradient(180deg, #FFFBF0 0%, #FFF8ED 50%, #FFF3E6 100%);">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-10 right-10 w-64 h-64 rounded-full blur-3xl opacity-20" style="background: rgba(249, 115, 22, 1);"></div>
    <div class="absolute bottom-10 left-10 w-48 h-48 rounded-full blur-3xl opacity-20" style="background: rgba(220, 38, 38, 1);"></div>
  </div>

  <div class="max-w-6xl mx-auto relative z-10">
    <div class="text-center mb-10">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-4" style="background: rgba(249, 115, 22, 0.15);">
        <span class="text-lg">🍽️</span>
        <span class="font-heading font-semibold text-sm" style="color: #F97316;">Công thức nấu ăn</span>
      </div>
      <h1 class="font-accent italic text-3xl md:text-5xl mb-3" style="color: #F97316;">Ẩm Thực</h1>
      <p class="font-heading font-bold text-2xl md:text-3xl text-gray-800 mb-4">Ngon & Dễ Nấu</p>
      <p class="font-body text-gray-500 max-w-lg mx-auto">Tổng hợp công thức các món ăn truyền thống và hiện đại, nấu ngon cho cả gia đình yêu thương.</p>
    </div>

    <!-- Category Filter -->
    <div class="flex flex-wrap justify-center gap-2 mb-8">
      <%= link_to recipes_path, class: "inline-flex items-center gap-2 px-4 py-2 rounded-full font-heading font-semibold text-sm transition-shadow duration-200 #{@category.blank? ? 'text-white shadow-lg' : 'text-gray-600 bg-white shadow-sm hover:shadow-md'}", style: @category.blank? ? "background: linear-gradient(135deg, #F97316, #DC2626);" : "" do %>
        Tất cả
      <% end %>
      <% @categories.each do |key, label| %>
        <% color = Recipe::CATEGORY_COLORS[key] %>
        <%= link_to recipes_path(category: key), class: "inline-flex items-center gap-2 px-4 py-2 rounded-full font-heading font-semibold text-sm transition-shadow duration-200 #{@category == key ? 'text-white shadow-lg' : 'bg-white shadow-sm hover:shadow-md'}", style: @category == key ? "background: #{color};" : "color: #{color};" do %>
          <span><%= Recipe::CATEGORY_ICONS[key] %></span>
          <span><%= label %></span>
        <% end %>
      <% end %>
    </div>
  </div>
</section>

<!-- Recipes Grid -->
<section class="py-12 px-4 md:px-6 lg:px-8" style="background: linear-gradient(180deg, #FFF8ED 0%, #FFFBF8 100%);">
  <div class="max-w-6xl mx-auto">
    <% if @recipes.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @recipes.each do |recipe| %>
          <%= link_to recipe_detail_path(recipe), class: "group bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow duration-300 border border-gray-100" do %>
            <!-- Image -->
            <div class="aspect-video overflow-hidden relative" style="background: linear-gradient(135deg, <%= recipe.category_color %>15, <%= recipe.category_color %>05);">
              <% if recipe.image_url.present? %>
                <img src="<%= recipe.image_url %>" alt="<%= recipe.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" decoding="async">
              <% else %>
                <div class="w-full h-full flex items-center justify-center">
                  <span class="text-6xl opacity-30"><%= recipe.category_icon %></span>
                </div>
              <% end %>
              <!-- Category Badge -->
              <div class="absolute top-3 left-3">
                <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-heading font-semibold text-white shadow-lg" style="background: <%= recipe.category_color %>;">
                  <span><%= recipe.category_icon %></span>
                  <span><%= recipe.category_label %></span>
                </span>
              </div>
            </div>

            <!-- Content -->
            <div class="p-5">
              <h3 class="font-heading font-bold text-lg text-gray-800 mb-2 line-clamp-2 group-hover:text-gray-900"><%= recipe.title %></h3>
              <p class="font-body text-sm text-gray-500 line-clamp-3 mb-4 leading-relaxed"><%= truncate(strip_tags(recipe.content), length: 150) %></p>

              <div class="flex items-center justify-between">
                <span class="font-body text-xs text-gray-400"><%= recipe.created_at.strftime("%d/%m/%Y") %></span>
                <span class="inline-flex items-center gap-1 font-heading font-semibold text-xs group-hover:translate-x-1 transition-transform" style="color: <%= recipe.category_color %>;">
                  Xem công thức
                  <span>→</span>
                </span>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-16 bg-white rounded-3xl shadow-xl">
        <div class="w-24 h-24 rounded-full mx-auto mb-6 flex items-center justify-center" style="background: linear-gradient(135deg, #FED7AA, #FDBA74);">
          <span class="text-5xl">🍽️</span>
        </div>
        <h3 class="font-heading font-bold text-xl text-gray-700 mb-2">Chưa có công thức nào</h3>
        <p class="font-body text-gray-500">Các công thức nấu ăn sẽ được cập nhật sớm!</p>
      </div>
    <% end %>
  </div>
</section>
