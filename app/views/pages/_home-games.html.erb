<!-- Games & Fun Section -->
<section class="lazy-section py-16 px-4 md:px-6 lg:px-8 relative overflow-hidden" style="background: linear-gradient(180deg, #F8FDFC 0%, #FFFBF8 50%, #F8FDFC 100%);">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-10 right-10 w-48 h-48 rounded-full blur-3xl opacity-30" style="background: #C0DFD0;"></div>
    <div class="absolute bottom-10 left-10 w-40 h-40 rounded-full blur-3xl opacity-30" style="background: #F2C2C2;"></div>
  </div>

  <div class="max-w-6xl mx-auto relative z-10">
    <div class="text-center mb-12" data-controller="scroll-animate">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-4" style="background: rgba(193, 221, 216, 0.2);">
        <span style="color: #A8CEC8;">🎮</span>
        <span class="font-heading font-semibold text-sm" style="color: #7BB4AA;">Vui chơi</span>
      </div>
      <h2 class="font-accent italic text-3xl md:text-4xl mb-3" style="color: #E8B0B0;">Trò Chơi & Tương Tác</h2>
      <p class="font-body text-gray-500 max-w-md mx-auto">Khám phá kỷ niệm của bé theo những cách thú vị hơn!</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5" data-controller="scroll-animate" data-scroll-animate-delay-value="150">
      <%= link_to games_memory_path, class: "group glass-card rounded-2xl p-6 shadow-lg cursor-pointer border border-white/50 transition-all duration-300 hover:shadow-xl hover:scale-[1.02]" do %>
        <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-4 shadow-md text-3xl" style="background: linear-gradient(135deg, #C1DDD8, #A8CEC8);">🃏</div>
        <h3 class="font-heading font-bold text-lg text-gray-800 mb-2">Memory Game</h3>
        <p class="font-body text-sm text-gray-500 mb-3 leading-relaxed">Lật thẻ và tìm cặp ảnh giống nhau. Thử thách trí nhớ của bạn!</p>
        <div class="flex items-center gap-1 font-heading font-semibold text-xs" style="color: #A8CEC8;">
          <span>Chơi ngay</span><span class="group-hover:translate-x-1 transition-transform">→</span>
        </div>
      <% end %>

      <%= link_to games_guess_age_path, class: "group glass-card rounded-2xl p-6 shadow-lg cursor-pointer border border-white/50 transition-all duration-300 hover:shadow-xl hover:scale-[1.02]" do %>
        <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-4 shadow-md text-3xl" style="background: linear-gradient(135deg, #F2C2C2, #E8B0B0);">🧒</div>
        <h3 class="font-heading font-bold text-lg text-gray-800 mb-2">Đoán Tuổi Nacon</h3>
        <p class="font-body text-sm text-gray-500 mb-3 leading-relaxed">Nhìn ảnh và đoán Nacon bao nhiêu tuổi. Bạn hiểu Nacon bao nhiêu?</p>
        <div class="flex items-center gap-1 font-heading font-semibold text-xs" style="color: #E8B0B0;">
          <span>Chơi ngay</span><span class="group-hover:translate-x-1 transition-transform">→</span>
        </div>
      <% end %>

      <%= link_to spin_wheel_path, class: "group glass-card rounded-2xl p-6 shadow-lg cursor-pointer border border-white/50 transition-all duration-300 hover:shadow-xl hover:scale-[1.02]" do %>
        <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-4 shadow-md text-3xl" style="background: linear-gradient(135deg, #C0DFD0, #A8D1BD);">🎡</div>
        <h3 class="font-heading font-bold text-lg text-gray-800 mb-2">Vòng Quay Thưởng Phạt</h3>
        <p class="font-body text-sm text-gray-500 mb-3 leading-relaxed">Quay vòng quay thưởng phạt vui vẻ cùng gia đình dịp Tết!</p>
        <div class="flex items-center gap-1 font-heading font-semibold text-xs" style="color: #A8D1BD;">
          <span>Quay ngay</span><span class="group-hover:translate-x-1 transition-transform">→</span>
        </div>
      <% end %>

      <%= link_to then_vs_now_path, class: "group glass-card rounded-2xl p-6 shadow-lg cursor-pointer border border-white/50 transition-all duration-300 hover:shadow-xl hover:scale-[1.02]" do %>
        <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-4 shadow-md text-3xl" style="background: linear-gradient(135deg, #DBEAFE, #93C5FD);">🔄</div>
        <h3 class="font-heading font-bold text-lg text-gray-800 mb-2">Then vs Now</h3>
        <p class="font-body text-sm text-gray-500 mb-3 leading-relaxed">So sánh ảnh trước và bây giờ, cảm nhận sự trưởng thành!</p>
        <div class="flex items-center gap-1 font-heading font-semibold text-xs" style="color: #3B82F6;">
          <span>Xem ngay</span><span class="group-hover:translate-x-1 transition-transform">→</span>
        </div>
      <% end %>

      <%= link_to recap_path, class: "group glass-card rounded-2xl p-6 shadow-lg cursor-pointer border border-white/50 transition-all duration-300 hover:shadow-xl hover:scale-[1.02]" do %>
        <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-4 shadow-md text-3xl" style="background: linear-gradient(135deg, #C0DFD0, #A8D1BD);">📊</div>
        <h3 class="font-heading font-bold text-lg text-gray-800 mb-2">Tổng Kết Tháng</h3>
        <p class="font-body text-sm text-gray-500 mb-3 leading-relaxed">Tổng kết kỷ niệm và milestones theo từng tháng.</p>
        <div class="flex items-center gap-1 font-heading font-semibold text-xs" style="color: #8BB8AA;">
          <span>Xem ngay</span><span class="group-hover:translate-x-1 transition-transform">→</span>
        </div>
      <% end %>

      <%= link_to growth_chart_path, class: "group glass-card rounded-2xl p-6 shadow-lg cursor-pointer border border-white/50 transition-all duration-300 hover:shadow-xl hover:scale-[1.02]" do %>
        <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-4 shadow-md text-3xl" style="background: linear-gradient(135deg, #C1DDD8, #A8CEC8);">📈</div>
        <h3 class="font-heading font-bold text-lg text-gray-800 mb-2">Biểu Đồ Tăng Trưởng Cho Nacon</h3>
        <p class="font-body text-sm text-gray-500 mb-3 leading-relaxed">Theo dõi chiều cao, cân nặng và vòng đầu của bé.</p>
        <div class="flex items-center gap-1 font-heading font-semibold text-xs" style="color: #A8CEC8;">
          <span>Xem ngay</span><span class="group-hover:translate-x-1 transition-transform">→</span>
        </div>
      <% end %>
    </div>
  </div>
</section>
