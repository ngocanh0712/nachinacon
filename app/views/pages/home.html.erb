<% content_for :og_tags do %>
  <meta property="og:title" content="NaChiNaCon - Kỷ niệm của bé">
  <meta property="og:description" content="Website lưu giữ kỷ niệm đáng yêu của bé Nacon">
  <meta property="og:type" content="website">
  <meta property="og:url" content="<%= request.original_url %>">
  <meta property="og:locale" content="vi_VN">
  <meta property="og:site_name" content="NaChiNaCon">
  <% if @featured_memory&.has_image? %>
    <% if @featured_memory.image_path.present? %>
      <meta property="og:image" content="<%= @featured_memory.image_path %>">
    <% elsif @featured_memory.media.attached? %>
      <meta property="og:image" content="<%= url_for(@featured_memory.media) %>">
    <% end %>
  <% end %>
<% end %>

<%= render 'pages/home-hero' %>
<%= render 'pages/home-featured-memory' %>
<%= render 'shared/memory-box', memories: @memory_box, milestones: @milestones_on_this_day %>
<%= render 'pages/home-recent-memories' %>
<%= render 'pages/home-milestones' %>
<%= render 'pages/home-games' %>
<%= render 'pages/home-content-sections' %>
<%= render 'shared/memory_modal' %>
