<div class="space-y-8">
  <!-- Header -->
  <div class="flex items-center justify-between">
    <div>
      <h1 class="font-heading font-bold text-2xl text-gray-800">Nhật Ký Hàng Ngày</h1>
      <p class="font-body text-sm text-gray-500 mt-1"><%= @daily_journals.count %> bài nhật ký</p>
    </div>
    <%= link_to new_admin_daily_journal_path, class: "inline-flex items-center gap-2 px-5 py-2.5 rounded-xl font-heading font-semibold text-gray-800 shadow-md hover:shadow-lg transition-all", style: "background: linear-gradient(135deg, #C1DDD8 0%, #A8CEC8 100%);" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
      Thêm nhật ký
    <% end %>
  </div>

  <% if @daily_journals.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <% @daily_journals.each do |journal| %>
        <div class="bg-white rounded-2xl p-5 shadow-md hover:shadow-lg transition-shadow duration-300">
          <div class="flex items-start gap-3 mb-3">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0 text-xl" style="background: <%= journal.mood_color %>20;">
              <span><%= journal.mood_emoji %></span>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="font-heading font-semibold text-gray-800"><%= journal.date.strftime("%d/%m/%Y") %></h3>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-heading font-medium mt-1" style="background: <%= journal.mood_color %>15; color: <%= journal.mood_color %>;">
                <%= journal.mood_label %>
              </span>
            </div>
          </div>

          <% if journal.sleep_hours.present? %>
            <p class="font-body text-sm text-gray-500 mb-1">
              <span class="font-semibold">Ngủ:</span> <%= journal.sleep_hours %> giờ
            </p>
          <% end %>

          <p class="font-body text-sm text-gray-500 line-clamp-2 mb-3"><%= journal.preview_text %></p>

          <div class="flex items-center gap-2 pt-3 border-t border-gray-100">
            <%= link_to edit_admin_daily_journal_path(journal), class: "flex-1 flex items-center justify-center gap-2 px-3 py-2 rounded-lg font-heading font-medium text-sm text-gray-700 transition-colors hover:bg-gray-100", style: "background-color: #E0EEEB;" do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
              </svg>
              Sửa
            <% end %>
            <%= button_to admin_daily_journal_path(journal), method: :delete, data: { turbo_confirm: "Xoá nhật ký này?" }, class: "flex-1 flex items-center justify-center gap-2 px-3 py-2 rounded-lg font-heading font-medium text-sm text-gray-700 transition-colors cursor-pointer", style: "background-color: #F8D8D8;", onmouseover: "this.style.backgroundColor='#FEE2E2'", onmouseout: "this.style.backgroundColor='#F8D8D8'" do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
              </svg>
              Xoá
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-white rounded-2xl p-12 text-center shadow-sm">
      <div class="w-20 h-20 rounded-full mx-auto mb-4 flex items-center justify-center text-4xl" style="background-color: #E0EEEB;">
        📔
      </div>
      <p class="font-heading font-semibold text-gray-700 mb-2">Chưa có nhật ký nào</p>
      <p class="font-body text-gray-500 mb-4">Ghi chép nhật ký hàng ngày cho bé.</p>
      <%= link_to new_admin_daily_journal_path, class: "inline-flex items-center gap-2 px-5 py-2.5 rounded-xl font-heading font-semibold text-white shadow-md", style: "background: linear-gradient(135deg, #C1DDD8, #A8CEC8);" do %>
        Thêm nhật ký đầu tiên
      <% end %>
    </div>
  <% end %>
</div>
