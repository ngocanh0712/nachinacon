<%= form_with(model: [:admin, daily_journal], class: "space-y-6") do |f| %>
  <% if daily_journal.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-xl p-4">
      <p class="font-heading font-semibold text-red-700 mb-2">Có lỗi xảy ra:</p>
      <ul class="list-disc list-inside font-body text-sm text-red-600">
        <% daily_journal.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- Date -->
  <div>
    <label class="block font-heading font-semibold text-sm text-gray-700 mb-2">Ngày *</label>
    <%= f.date_field :date, class: "w-full px-4 py-3 rounded-xl border border-gray-200 font-body text-gray-700 focus:outline-none focus:ring-2 focus:ring-opacity-50 transition-all" %>
  </div>

  <!-- Mood -->
  <div>
    <label class="block font-heading font-semibold text-sm text-gray-700 mb-2">Tâm trạng *</label>
    <div class="grid grid-cols-4 gap-3">
      <% DailyJournal::MOODS.each do |key, value| %>
        <label class="relative cursor-pointer">
          <%= f.radio_button :mood, key, class: "peer sr-only" %>
          <div class="flex flex-col items-center gap-1 p-3 rounded-xl border-2 border-gray-200 peer-checked:border-2 transition-all hover:bg-gray-50" style="peer-checked:border-color: <%= DailyJournal::MOOD_COLORS[key] %>;">
            <span class="text-2xl"><%= DailyJournal::MOOD_EMOJIS[key] %></span>
            <span class="font-heading text-xs font-medium text-gray-600"><%= DailyJournal::MOOD_LABELS[key] %></span>
          </div>
        </label>
      <% end %>
    </div>
  </div>

  <!-- Sleep Hours -->
  <div>
    <label class="block font-heading font-semibold text-sm text-gray-700 mb-2">Giờ ngủ</label>
    <%= f.number_field :sleep_hours, step: 0.5, min: 0, max: 24, class: "w-full px-4 py-3 rounded-xl border border-gray-200 font-body text-gray-700 focus:outline-none focus:ring-2 focus:ring-opacity-50 transition-all", placeholder: "VD: 10.5" %>
  </div>

  <!-- Eat Note -->
  <div>
    <label class="block font-heading font-semibold text-sm text-gray-700 mb-2">Ăn uống</label>
    <%= f.text_area :eat_note, rows: 3, class: "w-full px-4 py-3 rounded-xl border border-gray-200 font-body text-gray-700 focus:outline-none focus:ring-2 focus:ring-opacity-50 transition-all", placeholder: "Bé ăn gì hôm nay?" %>
  </div>

  <!-- Activity Note -->
  <div>
    <label class="block font-heading font-semibold text-sm text-gray-700 mb-2">Hoạt động</label>
    <%= f.text_area :activity_note, rows: 3, class: "w-full px-4 py-3 rounded-xl border border-gray-200 font-body text-gray-700 focus:outline-none focus:ring-2 focus:ring-opacity-50 transition-all", placeholder: "Bé chơi gì, làm gì hôm nay?" %>
  </div>

  <!-- General Note -->
  <div>
    <label class="block font-heading font-semibold text-sm text-gray-700 mb-2">Ghi chú</label>
    <%= f.text_area :note, rows: 4, class: "w-full px-4 py-3 rounded-xl border border-gray-200 font-body text-gray-700 focus:outline-none focus:ring-2 focus:ring-opacity-50 transition-all", placeholder: "Ghi chú thêm..." %>
  </div>

  <!-- Submit -->
  <div class="flex items-center gap-3 pt-4">
    <%= f.submit daily_journal.new_record? ? "Tạo nhật ký" : "Cập nhật", class: "px-6 py-3 rounded-xl font-heading font-semibold text-white shadow-lg hover:shadow-xl transition-all cursor-pointer", style: "background: linear-gradient(135deg, #C1DDD8 0%, #A8CEC8 100%);" %>
    <%= link_to "Huỷ", admin_daily_journals_path, class: "px-6 py-3 rounded-xl font-heading font-semibold text-gray-600 bg-gray-100 hover:bg-gray-200 transition-all" %>
  </div>
<% end %>
