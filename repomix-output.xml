                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <span class="font-heading font-medium text-gray-700 text-sm"><%= flash[:notice] %></span>
          </div>
        </div>
      <% end %>
      <% if flash[:alert] %>
        <div id="flash-alert" class="fixed top-20 lg:top-4 right-4 z-50 px-5 py-3 rounded-xl shadow-lg bg-white border" style="border-color: #F2C2C2;">
          <div class="flex items-center gap-3">
            <div class="w-7 h-7 rounded-full flex items-center justify-center" style="background: #F2C2C2;">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-white">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
              </svg>
            </div>
            <span class="font-heading font-medium text-gray-700 text-sm"><%= flash[:alert] %></span>
          </div>
        </div>
      <% end %>

      <!-- Page Content -->
      <div class="p-4 md:p-6 lg:p-8 pt-20 lg:pt-4">
        <%= yield %>
      </div>
    </main>

  <% else %>
    <!-- Not logged in - just render content -->
    <%= yield %>
  <% end %>

  <script>
    // Mobile menu toggle
    document.getElementById('mobile-menu-toggle')?.addEventListener('click', function() {
      document.getElementById('mobile-sidebar').classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    });

    document.getElementById('mobile-menu-close')?.addEventListener('click', closeMobileMenu);
    document.getElementById('mobile-sidebar-backdrop')?.addEventListener('click', closeMobileMenu);

    function closeMobileMenu() {
      document.getElementById('mobile-sidebar').classList.add('hidden');
      document.body.style.overflow = '';
    }

    // Auto-hide flash messages
    setTimeout(() => {
      ['flash-notice', 'flash-alert'].forEach(id => {
        const el = document.getElementById(id);
        if (el) {
          el.style.opacity = '0';
          el.style.transition = 'opacity 0.5s ease';
          setTimeout(() => el.remove(), 500);
        }
      });
    }, 4000);
  </script>
</body>
</html>
