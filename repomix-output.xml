          <span class="shimmer-text"><%= SiteSetting.get('baby_name') %></span>
        </h1>

        <!-- Decorative line -->
        <div class="flex items-center gap-3 justify-center lg:justify-start mb-6">
          <div class="w-16 h-1 rounded-full gradient-animated"></div>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 floating" style="color: #E8B0B0;">
            <path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.003-.001z" />
          </svg>
          <div class="w-16 h-1 rounded-full gradient-animated"></div>
        </div>
        <% birth_date = SiteSetting.baby_birth_date %>
        <% years, months = calculate_age(birth_date) %>
        <!-- Age Display - Glass morphism -->
        <div class="inline-flex items-center gap-4 glass-card rounded-2xl px-6 py-4 shadow-xl mb-8">
          <div class="w-14 h-14 rounded-xl flex items-center justify-center gradient-animated shadow-lg">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-7 h-7 text-white">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8.25v-1.5m0 1.5c-1.355 0-2.697.056-4.024.166C6.845 8.51 6 9.473 6 10.608v2.513m6-4.87c1.355 0 2.697.055 4.024.165C17.155 8.51 18 9.473 18 10.608v2.513m-3-4.87v-1.5m-6 1.5v-1.5m12 9.75l-1.5.75a3.354 3.354 0 01-3 0 3.354 3.354 0 00-3 0 3.354 3.354 0 01-3 0 3.354 3.354 0 00-3 0 3.354 3.354 0 01-3 0L3 16.5m15-3.38a48.474 48.474 0 00-6-.37c-2.032 0-4.034.125-6 .37m12 0c.39.049.777.102 1.163.16 1.07.16 1.837 1.094 1.837 2.175v5.17c0 .62-.504 1.124-1.125 1.124H4.125A1.125 1.125 0 013 20.625v-5.17c0-1.08.768-2.014 1.837-2.174A47.78 47.78 0 016 13.12M12 12.75h.008v.008H12v-.008z" />
            </svg>
          </div>
          <div>
            <p class="font-body text-sm text-gray-500"><%= SiteSetting.get('baby_nickname') %></p>
            <p class="font-heading font-bold text-2xl text-gray-800"><%= "#{years} năm, #{months} tháng" %></p>
          </div>
        </div>

        <p class="font-body text-lg md:text-xl text-gray-600 mb-8 max-w-xl mx-auto lg:mx-0 leading-relaxed">
          Ghi lại từng khoảnh khắc quý giá của hoàng tử nhỏ. Từ nụ cười đầu tiên đến bước chân đầu tiên, mỗi kỷ niệm đều là báu vật.
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <%= link_to timeline_path, class: "group inline-flex items-center justify-center gap-3 text-white font-heading font-semibold px-8 py-4 rounded-xl shadow-xl cursor-pointer transition-all duration-300 hover:shadow-2xl hover:scale-105 gradient-animated", style: "background-size: 200% 200%;" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 group-hover:rotate-12 transition-transform">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>Xem Timeline</span>
          <% end %>
          <%= link_to milestones_path, class: "group inline-flex items-center justify-center gap-3 bg-white text-gray-700 font-heading font-semibold px-8 py-4 rounded-xl shadow-lg cursor-pointer border-2 border-gray-100 transition-all duration-300 hover:shadow-xl hover:border-gray-200 hover:scale-105" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 group-hover:rotate-12 transition-transform" style="color: #E8B0B0;">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
            </svg>
            <span>Milestones</span>
          <% end %>
        </div>
      </div>

      <!-- Hero Image/Avatar -->
      <div class="flex-1 flex justify-center">
        <div class="relative">
          <!-- Rotating ring -->
          <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-80 h-80 md:w-96 md:h-96 lg:w-[28rem] lg:h-[28rem] rounded-full rotate-slow" style="border: 3px dashed rgba(193, 221, 216, 0.3);"></div>

          <!-- Main photo frame -->
          <div class="relative w-72 h-72 md:w-80 md:h-80 lg:w-96 lg:h-96 rounded-full p-4 shadow-2xl gradient-animated" style="background-size: 200% 200%;">
            <div class="w-full h-full bg-white rounded-full flex items-center justify-center overflow-hidden shadow-inner">
              <%= image_tag 'family-photo.jpg',
                  class: 'w-full h-full object-cover',
                  alt: 'Ảnh gia đình',
                  onerror: "this.style.display='none'; this.nextElementSibling.style.display='flex'" %>
              <!-- Fallback placeholder if image not found -->
              <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-gray-50 to-gray-100" style="display: none;">
                <div class="text-center">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="w-20 h-20 text-gray-300 mx-auto mb-2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.182 15.182a4.5 4.5 0 01-6.364 0M21 12a9 9 0 11-18 0 9 9 0 0118 0zM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75zm-.375 0h.008v.015h-.008V9.75zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75zm-.375 0h.008v.015h-.008V9.75z" />
                  </svg>
                  <p class="font-body text-gray-400 text-sm">Ảnh gia đình</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Decorative floating elements -->
          <div class="absolute -top-4 -right-4 w-20 h-20 rounded-2xl flex items-center justify-center shadow-xl floating" style="background: linear-gradient(135deg, #F2C2C2, #E8B0B0);">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-10 h-10 text-white">
              <path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.003-.001z" />
            </svg>
          </div>

          <div class="absolute -bottom-2 -left-6 w-16 h-16 rounded-2xl flex items-center justify-center shadow-xl floating-delay-1 text-3xl" style="background: linear-gradient(135deg, #C0DFD0, #A8D1BD);">
            <span class="text-white">⭐</span>
          </div>

          <div class="absolute top-1/2 -right-10 w-14 h-14 rounded-2xl flex items-center justify-center shadow-xl floating-delay-2 text-2xl" style="background: linear-gradient(135deg, #C1DDD8, #A8CEC8);">
            <span class="text-white">✨</span>
          </div>

          <div class="absolute bottom-1/4 -left-8 w-12 h-12 rounded-full flex items-center justify-center shadow-lg floating-delay-3 text-xl" style="background: linear-gradient(135deg, #FEF3C7, #F59E0B);">
            <span class="text-white">⭐</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Stats & Search Section -->
<section class="py-10 px-4 md:px-6 lg:px-8 -mt-12 relative z-20">
  <div class="max-w-6xl mx-auto">
    <div class="rounded-3xl p-6 md:p-8 shadow-2xl relative overflow-hidden" style="background: linear-gradient(135deg, #FDFBF9 0%, #F8FDFC 50%, #FFFBF8 100%);">
      <!-- Decorative elements -->
      <div class="absolute top-0 right-0 w-32 h-32 rounded-full blur-3xl opacity-20" style="background: #C1DDD8;"></div>
      <div class="absolute bottom-0 left-0 w-24 h-24 rounded-full blur-3xl opacity-20" style="background: #F2C2C2;"></div>

      <!-- Search Bar -->
      <%= form_with url: search_path, method: :get, class: "mb-8 relative z-10" do %>
        <div class="relative rounded-2xl overflow-hidden shadow-lg" style="background: linear-gradient(135deg, rgba(193, 221, 216, 0.08), rgba(242, 194, 194, 0.08));">
          <div class="flex gap-2 p-1.5">
            <%= text_field_tag :q, params[:q],
                placeholder: "Tìm kiếm kỷ niệm của bé...",
                class: "flex-1 px-5 py-3.5 rounded-xl font-body text-gray-700 placeholder-gray-400 transition-all duration-200 focus:outline-none bg-white border-0 focus:shadow-md",
                style: "box-shadow: 0 1px 3px rgba(193, 221, 216, 0.1);" %>
            <%= button_tag type: "submit", class: "px-6 py-3.5 rounded-xl font-heading font-semibold text-white transition-all duration-200 hover:shadow-xl hover:scale-105 shadow-lg", style: "background: linear-gradient(135deg, #C1DDD8 0%, #A8CEC8 50%, #9FC4BC 100%);" do %>
              <span class="flex items-center gap-2">
                <span class="text-lg">🔍</span>
                <span class="hidden sm:inline">Tìm kiếm</span>
              </span>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- Stats Grid -->
      <div class="grid grid-cols-3 gap-3 md:gap-6 relative z-10">
        <div class="group relative rounded-2xl p-4 md:p-6 text-center transition-all duration-300 hover:scale-105" style="background: linear-gradient(135deg, rgba(193, 221, 216, 0.15), rgba(168, 206, 200, 0.1));">
          <div class="inline-flex items-center justify-center w-12 h-12 md:w-14 md:h-14 rounded-xl mb-2 md:mb-3 text-2xl md:text-3xl shadow-lg transition-transform group-hover:rotate-12" style="background: linear-gradient(135deg, #C1DDD8, #A8CEC8);">
            <span class="filter drop-shadow-sm">📸</span>
          </div>
          <p class="font-heading font-bold text-2xl md:text-3xl text-gray-800 mb-1"><%= @memory_count %></p>
          <p class="font-body text-xs md:text-sm text-gray-600">Kỷ niệm</p>
        </div>

        <div class="group relative rounded-2xl p-4 md:p-6 text-center transition-all duration-300 hover:scale-105" style="background: linear-gradient(135deg, rgba(16, 185, 129, 0.15), rgba(5, 150, 105, 0.1));">
          <div class="inline-flex items-center justify-center w-12 h-12 md:w-14 md:h-14 rounded-xl mb-2 md:mb-3 text-2xl md:text-3xl shadow-lg transition-transform group-hover:rotate-12" style="background: linear-gradient(135deg, #10B981, #059669);">
            <span class="filter drop-shadow-sm">🏆</span>
          </div>
          <p class="font-heading font-bold text-2xl md:text-3xl text-gray-800 mb-1"><%= @milestone_count %></p>
          <p class="font-body text-xs md:text-sm text-gray-600">Milestones</p>
        </div>

        <div class="group relative rounded-2xl p-4 md:p-6 text-center transition-all duration-300 hover:scale-105" style="background: linear-gradient(135deg, rgba(242, 194, 194, 0.15), rgba(232, 176, 176, 0.1));">
          <div class="inline-flex items-center justify-center w-12 h-12 md:w-14 md:h-14 rounded-xl mb-2 md:mb-3 text-2xl md:text-3xl shadow-lg transition-transform group-hover:rotate-12" style="background: linear-gradient(135deg, #F2C2C2, #E8B0B0);">
            <span class="filter drop-shadow-sm">🎂</span>
          </div>
          <p class="font-heading font-bold text-2xl md:text-3xl text-gray-800 mb-1"><%= @days_old %></p>
          <p class="font-body text-xs md:text-sm text-gray-600">Ngày tuổi</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Featured Memory of the Day -->
<% if @featured_memory %>
<section class="py-12 px-4 md:px-6 lg:px-8 relative overflow-hidden" style="background: linear-gradient(180deg, #FFFBF8 0%, #F8FDFC 100%);">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-10 right-10 w-64 h-64 rounded-full blur-3xl pulse-glow" style="background: rgba(193, 221, 216, 0.2);"></div>
    <div class="absolute bottom-10 left-10 w-48 h-48 rounded-full blur-3xl pulse-glow" style="background: rgba(242, 194, 194, 0.2); animation-delay: 2s;"></div>
  </div>

  <div class="max-w-6xl mx-auto relative z-10">
    <div class="text-center mb-10">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-4" style="background: rgba(193, 221, 216, 0.2);">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4" style="color: #A8CEC8;">
          <path d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
        </svg>
        <span class="font-heading font-semibold text-sm" style="color: #7BB4AA;">Nổi bật hôm nay</span>
      </div>
      <h2 class="font-accent italic text-3xl md:text-4xl mb-3" style="color: #E8B0B0;">Kỷ Niệm Đặc Biệt</h2>
    </div>

    <div class="glass-card rounded-3xl overflow-hidden shadow-2xl max-w-4xl mx-auto">
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Image -->
        <div class="relative overflow-hidden group aspect-square md:aspect-auto">
          <% if @featured_memory.image_path.present? %>
            <%= image_tag @featured_memory.image_path, class: "w-full h-full object-cover group-hover:scale-110 transition-transform duration-500", alt: @featured_memory.title %>
          <% elsif @featured_memory.media.attached? %>
            <%= optimized_image_tag(@featured_memory.media, :large, class: "w-full h-full object-cover group-hover:scale-110 transition-transform duration-500", alt: @featured_memory.title) %>
          <% end %>
          <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        </div>

        <!-- Content -->
        <div class="p-8 flex flex-col justify-center">
          <% age_label = Memory::AGE_GROUPS.find { |_, v| v == @featured_memory.age_group }&.first || @featured_memory.age_group %>
          <span class="inline-block px-4 py-2 rounded-full text-sm font-heading font-semibold mb-4" style="background: rgba(193, 221, 216, 0.2); color: #5A9A8E; width: fit-content;">
            <%= age_label %>
          </span>

          <h3 class="font-heading font-bold text-3xl text-gray-800 mb-4"><%= @featured_memory.title %></h3>

          <% if @featured_memory.caption.present? %>
            <p class="font-body text-gray-600 mb-6 leading-relaxed"><%= @featured_memory.caption %></p>
          <% end %>

          <div class="flex items-center gap-4 text-sm text-gray-500 mb-6">
            <div class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5" style="color: #A8CEC8;">
                <path fill-rule="evenodd" d="M6.75 2.25A.75.75 0 017.5 3v1.5h9V3A.75.75 0 0118 3v1.5h.75a3 3 0 013 3v11.25a3 3 0 01-3 3H5.25a3 3 0 01-3-3V7.5a3 3 0 013-3H6V3a.75.75 0 01.75-.75zm13.5 9a1.5 1.5 0 00-1.5-1.5H5.25a1.5 1.5 0 00-1.5 1.5v7.5a1.5 1.5 0 001.5 1.5h13.5a1.5 1.5 0 001.5-1.5v-7.5z" clip-rule="evenodd" />
              </svg>
              <span class="font-body"><%= @featured_memory.taken_at.strftime("%d/%m/%Y") %></span>
            </div>
          </div>

          <!-- Tags -->
          <% if @featured_memory.tags.any? %>
            <div class="flex flex-wrap gap-2 mb-6">
              <% @featured_memory.tags.each do |tag| %>
                <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-body font-medium" style="background-color: <%= tag.color %>20; color: <%= tag.color %>;">
                  <%= tag.name %>
                </span>
              <% end %>
            </div>
          <% end %>

          <%= link_to timeline_path, class: "inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl font-heading font-semibold text-white shadow-lg transition-all duration-300 hover:shadow-xl hover:scale-105", style: "background: linear-gradient(135deg, #C1DDD8 0%, #A8CEC8 100%); width: fit-content;" do %>
            <span>Xem chi tiết</span>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>
<% end %>
<!-- Quick Links Section -->
<section class="hidden md:block py-16 px-4 md:px-6 lg:px-8 bg-white relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute top-0 right-0 w-64 h-64 rounded-full blur-3xl opacity-30" style="background: #C1DDD8;"></div>
  <div class="absolute bottom-0 left-0 w-48 h-48 rounded-full blur-3xl opacity-30" style="background: #F2C2C2;"></div>

  <div class="max-w-6xl mx-auto relative z-10">
    <div class="text-center mb-12">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-4" style="background: rgba(242, 194, 194, 0.2);">
        <span style="color: #E8B0B0;">✨</span>
        <span class="font-heading font-semibold text-sm" style="color: #D4A0A0;">Khám phá</span>
      </div>
      <h2 class="font-accent italic text-3xl md:text-4xl mb-3" style="color: #C1DDD8;">Những Khoảnh Khắc</h2>
      <p class="font-heading font-bold text-2xl md:text-3xl text-gray-800">Quý Giá Của Nacon</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Timeline Card -->
      <%= link_to timeline_path, class: "group card-3d glass-card rounded-3xl p-8 shadow-xl cursor-pointer border border-white/50" do %>
        <div class="w-18 h-18 rounded-2xl flex items-center justify-center mb-6 shadow-lg relative overflow-hidden" style="background: linear-gradient(135deg, #E0EEEB, #C1DDD8);">
          <div class="absolute inset-0 bg-white/20 group-hover:bg-white/30 transition-colors"></div>
          <div class="text-5xl relative z-10">🕐</div>
        </div>
        <h3 class="font-heading font-bold text-xl text-gray-800 mb-3">Timeline</h3>
        <p class="font-body text-gray-600 mb-4 leading-relaxed">Hành trình từng khoảnh khắc, được sắp xếp theo từng giai đoạn tuổi.</p>
        <div class="flex items-center gap-2 font-heading font-semibold text-sm" style="color: #A8CEC8;">
          <span>Xem Timeline</span>
          <span class="group-hover:translate-x-2 transition-transform duration-300">→</span>
        </div>
      <% end %>

      <!-- Milestones Card -->
      <%= link_to milestones_path, class: "group card-3d glass-card rounded-3xl p-8 shadow-xl cursor-pointer border border-white/50" do %>
        <div class="w-18 h-18 rounded-2xl flex items-center justify-center mb-6 shadow-lg relative overflow-hidden" style="background: linear-gradient(135deg, #F8D8D8, #F2C2C2);">
          <div class="absolute inset-0 bg-white/20 group-hover:bg-white/30 transition-colors"></div>
          <div class="text-5xl relative z-10">⭐</div>
        </div>
        <h3 class="font-heading font-bold text-xl text-gray-800 mb-3">Milestones</h3>
        <p class="font-body text-gray-600 mb-4 leading-relaxed">Những mốc quan trọng - nụ cười đầu tiên, từ đầu tiên, bước đi đầu tiên.</p>
        <div class="flex items-center gap-2 font-heading font-semibold text-sm" style="color: #E8B0B0;">
          <span>Xem Milestones</span>
          <span class="group-hover:translate-x-2 transition-transform duration-300">→</span>
        </div>
      <% end %>

      <!-- Albums Card -->
      <%= link_to albums_path, class: "group card-3d glass-card rounded-3xl p-8 shadow-xl cursor-pointer border border-white/50" do %>
        <div class="w-18 h-18 rounded-2xl flex items-center justify-center mb-6 shadow-lg relative overflow-hidden" style="background: linear-gradient(135deg, rgba(192, 223, 208, 0.9), #C0DFD0);">
          <div class="absolute inset-0 bg-white/20 group-hover:bg-white/30 transition-colors"></div>
          <div class="text-5xl relative z-10 text-white">📁</div>
        </div>
        <h3 class="font-heading font-bold text-xl text-gray-800 mb-3">Albums</h3>
        <p class="font-body text-gray-600 mb-4 leading-relaxed">Xem tất cả ảnh và video trong bộ sưu tập kỷ niệm đẹp.</p>
        <div class="flex items-center gap-2 font-heading font-semibold text-sm" style="color: #A8D1BD;">
          <span>Xem Albums</span>
          <span class="group-hover:translate-x-2 transition-transform duration-300">→</span>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- Recent Memories Preview -->
<section class="py-16 px-4 md:px-6 lg:px-8 relative overflow-hidden" style="background: linear-gradient(180deg, #F8FAF9 0%, #FDFBF9 100%);">
  <!-- Background decoration -->
  <div class="absolute top-20 right-10 w-32 h-32 rounded-full blur-2xl opacity-40" style="background: #C0DFD0;"></div>
  <div class="absolute bottom-20 left-10 w-24 h-24 rounded-full blur-2xl opacity-40" style="background: #F2C2C2;"></div>

  <div class="max-w-6xl mx-auto relative z-10">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-10">
      <div>
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full mb-3" style="background: rgba(193, 221, 216, 0.2);">
          <div class="w-1.5 h-1.5 rounded-full" style="background: #A8CEC8;"></div>
          <span class="font-heading font-semibold text-xs" style="color: #7BB4AA;">Mới cập nhật</span>
        </div>
        <p class="font-accent text-xl md:text-2xl mb-2" style="color: #E8B0B0;">Mới nhất</p>
        <h2 class="font-accent font-bold text-3xl md:text-4xl text-gray-800 mb-2">Kỷ Niệm Gần Đây</h2>
      </div>
      <%= link_to timeline_path, class: "group mt-4 md:mt-0 inline-flex items-center gap-2 px-5 py-2.5 rounded-full font-heading font-semibold text-sm transition-all duration-300 hover:shadow-lg", style: "background: rgba(193, 221, 216, 0.2); color: #5A9A8E;" do %>
        <span>Xem tất cả</span>
        <span class="group-hover:translate-x-1 transition-transform">→</span>
      <% end %>
    </div>

    <% if @recent_memories.any? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <% memory_colors = [
          ['#FCE7F3', '#EC4899'],
          ['#D1FAE5', '#22C55E'],
          ['#DBEAFE', '#3B82F6'],
          ['#FEF3C7', '#F59E0B']
        ] %>
        <% @recent_memories.each_with_index do |memory, index| %>
          <% colors = memory_colors[index % memory_colors.length] %>
          <% age_label = Memory::AGE_GROUPS.find { |_, v| v == memory.age_group }&.first || memory.age_group %>
          <% image_url = if memory.image_path.present?
               memory.image_path
             elsif memory.media.attached?
               url_for(memory.media)
             else
               ''
             end %>
          <div class="memory-card group bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl cursor-pointer border border-gray-100 transition-all duration-300"
               data-turbo="false"
               data-memory-title="<%= memory.title %>"
               data-memory-date="<%= memory.taken_at.strftime("%d/%m/%Y") %>"
               data-memory-caption="<%= memory.caption %>"
               data-memory-image="<%= image_url %>"
               data-memory-age-group="<%= age_label %>"
               data-memory-age-color="<%= colors.join(';') %>"
               onclick="openMemoryModalFromData(this)">
            <div class="aspect-square flex items-center justify-center relative overflow-hidden" style="background: <%= colors[0] %>;">
              <% if memory.image_path.present? %>
                <%= image_tag memory.image_path, class: "w-full h-full object-cover", alt: memory.title || "Memory photo" %>
              <% elsif memory.media.attached? %>
                <%= optimized_image_tag(memory.media, :medium, class: "w-full h-full object-cover", alt: memory.title || "Memory photo") %>
              <% else %>
                <div class="text-6xl opacity-30" style="color: <%= colors[1] %>;">📷</div>
              <% end %>
              <!-- Overlay on hover -->
              <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                <div class="text-white font-heading font-semibold text-sm transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
                  Xem chi tiết
                </div>
              </div>
            </div>
            <div class="p-4">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-lg">📅</span>
                <p class="font-body text-xs text-gray-500"><%= memory.taken_at.strftime("%d/%m/%Y") %></p>
              </div>
              <h3 class="font-heading font-bold text-gray-800 mb-1 line-clamp-1"><%= memory.title %></h3>
              <% if memory.caption.present? %>
                <p class="font-body text-sm text-gray-500 line-clamp-2 mb-2"><%= memory.caption %></p>
              <% end %>

              <!-- Tags -->
              <% if memory.tags.any? %>
                <div class="flex flex-wrap gap-1 mt-2">
                  <% memory.tags.first(2).each do |tag| %>
                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-body font-medium" style="background-color: <%= tag.color %>20; color: <%= tag.color %>;">
                      <%= tag.name %>
                    </span>
                  <% end %>
                  <% if memory.tags.count > 2 %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-body font-medium text-gray-500" style="background-color: rgba(156, 163, 175, 0.15);">
                      +<%= memory.tags.count - 2 %>
                    </span>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-16 glass-card rounded-3xl shadow-xl">
        <div class="w-24 h-24 rounded-full mx-auto mb-6 flex items-center justify-center floating" style="background: linear-gradient(135deg, #E0EEEB, #C1DDD8);">
          <div class="text-6xl">📸</div>
        </div>
        <h3 class="font-heading font-bold text-xl text-gray-700 mb-2">Chưa có kỷ niệm nào</h3>
        <p class="font-body text-gray-500">Hãy thêm những khoảnh khắc đáng yêu của bé!</p>
      </div>
    <% end %>
  </div>
</section>

<!-- Achieved Milestones -->
<section class="py-16 px-4 md:px-6 lg:px-8 bg-white relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute top-0 left-1/4 w-48 h-48 rounded-full blur-3xl opacity-20" style="background: #F2C2C2;"></div>
  <div class="absolute bottom-0 right-1/4 w-40 h-40 rounded-full blur-3xl opacity-20" style="background: #C1DDD8;"></div>

  <div class="max-w-6xl mx-auto relative z-10">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-12">
      <div>
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full mb-3" style="background: rgba(16, 185, 129, 0.1);">
          <span style="color: #10B981;">✓</span>
          <span class="font-heading font-semibold text-xs" style="color: #059669;">Đã đạt được</span>
        </div>
        <p class="font-accent text-xl md:text-2xl mb-2" style="color: #E8B0B0;">Thành tựu</p>
        <h2 class="font-accent italic text-3xl md:text-4xl" style="color: #C1DDD8;">Milestones Đã Đạt</h2>
      </div>
      <%= link_to milestones_path, class: "group mt-4 md:mt-0 inline-flex items-center gap-2 px-5 py-2.5 rounded-full font-heading font-semibold text-sm transition-all duration-300 hover:shadow-lg", style: "background: rgba(242, 194, 194, 0.2); color: #D4A0A0;" do %>
        <span>Xem tất cả</span>
        <span class="group-hover:translate-x-1 transition-transform">→</span>
      <% end %>
    </div>

    <% if @achieved_milestones.any? %>
      <% pill_colors = [
        ['#FCE7F3', '#EC4899', '#BE185D'],
        ['#DBEAFE', '#3B82F6', '#1D4ED8'],
        ['#D1FAE5', '#22C55E', '#16A34A'],
        ['#FEF3C7', '#F59E0B', '#B45309'],
        ['#EDE9FE', '#A855F7', '#7C3AED'],
        ['#FFEDD5', '#F97316', '#C2410C'],
        ['#CFFAFE', '#06B6D4', '#0E7490'],
        ['#F5D0FE', '#D946EF', '#A21CAF']
      ] %>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        <% @achieved_milestones.each_with_index do |milestone, index| %>
          <% colors = pill_colors[index % pill_colors.length] %>
          <div class="milestone-pill flex items-center gap-3 px-5 py-4 rounded-2xl cursor-pointer shadow-lg border-2 transition-all duration-300" style="background: <%= colors[0] %>; border-color: <%= colors[1] %>30;">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0 text-xl" style="background: <%= colors[1] %>20;">
              <span style="color: <%= colors[1] %>;">⭐</span>
            </div>
            <span class="font-heading font-semibold text-sm line-clamp-2" style="color: <%= colors[2] %>;"><%= milestone.name %></span>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="glass-card rounded-3xl p-12 text-center shadow-xl">
        <div class="w-20 h-20 rounded-full mx-auto mb-6 flex items-center justify-center floating text-4xl" style="background: linear-gradient(135deg, #D1FAE5, #10B981);">
          <span class="text-white">⭐</span>
        </div>
        <h3 class="font-heading font-bold text-xl text-gray-700 mb-2">Chưa có milestone nào</h3>
        <p class="font-body text-gray-500">Những bước tiến của bé sẽ được ghi lại ở đây.</p>
      </div>
    <% end %>
  </div>
</section>

<!-- Popular Tags Cloud -->
<% if @popular_tags.any? %>
<section class="py-16 px-4 md:px-6 lg:px-8 bg-white">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-12">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-4" style="background: rgba(242, 194, 194, 0.2);">
        <span class="text-lg" style="color: #E8B0B0;">🏷️</span>
        <span class="font-heading font-semibold text-sm" style="color: #D4A0A0;">Chủ đề phổ biến</span>
      </div>
      <h2 class="font-accent italic text-3xl md:text-4xl" style="color: #C1DDD8;">Tags</h2>
    </div>

    <div class="flex flex-wrap justify-center gap-2 md:gap-3">
      <% @popular_tags.each do |tag| %>
        <% border_style = "border-color: #{tag.color}40; background-color: #{tag.color}10;" %>
        <% badge_style = "background: #{tag.color}30; color: #{tag.color};" %>
        <%= link_to timeline_path(tag: tag.id), class: "group inline-flex items-center gap-2 md:gap-3 px-3 py-2 md:px-6 md:py-3 rounded-xl md:rounded-2xl border-2 transition-all duration-300 hover:shadow-lg hover:scale-105", style: border_style do %>
          <span class="w-2 h-2 md:w-3 md:h-3 rounded-full flex-shrink-0" style="background: <%= tag.color %>;"></span>
          <span class="font-heading font-semibold text-xs md:text-sm text-gray-800"><%= tag.name %></span>
          <span class="px-1.5 md:px-2 py-0.5 rounded-full text-xs font-body font-medium" style="<%= badge_style %>">
            <%= tag.memory_count %>
          </span>
        <% end %>
      <% end %>
    </div>
  </div>
</section>
<% end %>

<%= render 'shared/memory_modal' %>
</file>

</files>
