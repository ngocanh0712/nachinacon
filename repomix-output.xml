      </div>
    </div>

    <!-- Mobile menu -->
    <div data-mobile-menu-target="menu" class="md:hidden overflow-hidden transition-all duration-300" style="max-height: 0; background-color: #FAFAFA;">
      <div class="px-4 py-4 space-y-1 border-t border-gray-100">
