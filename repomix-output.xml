        <%= link_to admin_settings_path, class: "flex items-center gap-3 px-4 py-3 rounded-xl font-heading font-semibold transition-colors duration-200 #{current_page?(admin_settings_path) ? 'text-gray-800' : 'text-gray-600 hover:bg-gray-50'}", style: current_page?(admin_settings_path) ? 'background-color: #E0EEEB;' : '' do %>
