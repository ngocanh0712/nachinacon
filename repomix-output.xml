  }

  .album-card:hover {
    transform: translateY(-12px) scale(1.02);
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.15);
  }

  .album-card:hover img {
    transform: scale(1.1);
  }

  .album-card img {
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .stat-card {
