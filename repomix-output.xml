            <div class="aspect-square overflow-hidden relative">
              <% if memory.image_path.present? %>
                <%= image_tag memory.image_path, class: "w-full h-full object-cover", alt: memory.title || "Memory photo" %>
              <% elsif memory.media.attached? %>
                <%= optimized_image_tag(memory.media, :medium, class: "w-full h-full object-cover", alt: memory.title || "Memory photo") %>
              <% else %>
                <div class="w-full h-full flex items-center justify-center" style="background: <%= colors[0] %>;">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="w-14 h-14" style="color: <%= colors[1] %>30;">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
                  </svg>
                </div>
              <% end %>

              <!-- Age badge -->
              <div class="absolute top-3 right-3 px-3 py-1.5 rounded-xl text-xs font-heading font-bold shadow-lg backdrop-blur-sm" style="background: <%= colors[0] %>ee; color: <%= colors[1] %>;">
                <%= age_label %>
              </div>

              <!-- Hover overlay -->
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                <div class="text-white font-heading font-semibold text-sm transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
                  Xem chi tiết
                </div>
              </div>
            </div>

            <div class="p-4">
              <div class="flex items-center gap-2 mb-2">
                <div class="w-6 h-6 rounded-lg flex items-center justify-center" style="background: <%= colors[0] %>;">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3 h-3" style="color: <%= colors[1] %>;">
                    <path fill-rule="evenodd" d="M6.75 2.25A.75.75 0 017.5 3v1.5h9V3A.75.75 0 0118 3v1.5h.75a3 3 0 013 3v11.25a3 3 0 01-3 3H5.25a3 3 0 01-3-3V7.5a3 3 0 013-3H6V3a.75.75 0 01.75-.75zm13.5 9a1.5 1.5 0 00-1.5-1.5H5.25a1.5 1.5 0 00-1.5 1.5v7.5a1.5 1.5 0 001.5 1.5h13.5a1.5 1.5 0 001.5-1.5v-7.5z" clip-rule="evenodd" />
                  </svg>
                </div>
                <p class="font-heading font-semibold text-xs" style="color: <%= colors[1] %>;"><%= memory.taken_at.strftime("%d/%m/%Y") %></p>
              </div>
              <h3 class="font-heading font-bold text-base text-gray-800 line-clamp-1 mb-1"><%= memory.title %></h3>
              <% if memory.caption.present? %>
                <p class="font-body text-xs text-gray-500 line-clamp-2 mb-2"><%= memory.caption %></p>
              <% end %>

              <!-- Tags -->
              <% if memory.tags.any? %>
                <div class="flex flex-wrap gap-1 mt-2">
                  <% memory.tags.first(2).each do |tag| %>
                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-body font-medium" style="background-color: <%= tag.color %>20; color: <%= tag.color %>;">
                      <%= tag.name %>
                    </span>
                  <% end %>
                  <% if memory.tags.count > 2 %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-body font-medium text-gray-500" style="background-color: rgba(156, 163, 175, 0.15);">
                      +<%= memory.tags.count - 2 %>
                    </span>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <!-- Empty State -->
      <div class="text-center py-20 glass-card rounded-3xl shadow-xl">
        <div class="w-24 h-24 rounded-full mx-auto mb-6 flex items-center justify-center floating gradient-animated">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12 text-white">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h3 class="font-heading font-bold text-2xl text-gray-700 mb-3">Chưa có kỷ niệm nào</h3>
        <p class="font-body text-gray-500 mb-6 max-w-md mx-auto">
          <% if @age_group.present? %>
            Không có kỷ niệm nào trong giai đoạn <span class="font-semibold" style="color: #C1DDD8;"><%= Memory::AGE_GROUPS.find { |_, v| v == @age_group }&.first %></span>.
          <% else %>
            Hãy thêm những khoảnh khắc đáng yêu của bé!
          <% end %>
        </p>
        <% if @age_group.present? %>
          <%= link_to timeline_path, class: "group inline-flex items-center gap-2 px-8 py-4 rounded-xl font-heading font-semibold text-white shadow-xl transition-all duration-300 hover:shadow-2xl hover:scale-105 gradient-animated" do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 group-hover:-translate-x-1 transition-transform">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 15L3 9m0 0l6-6M3 9h12a6 6 0 010 12h-3" />
            </svg>
            Xem tất cả kỷ niệm
          <% end %>
        <% end %>
      </div>
    <% end %>

    <!-- Pagination -->
    <%= render 'shared/pagination', pagy: @pagy %>
  </div>
</section>

