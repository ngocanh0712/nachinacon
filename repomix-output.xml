  task reset: :environment do
    puts "Resetting admin user..."

    # Delete old admin if exists
    old_admin = AdminUser.find_by(email: 'admin@nachinacon.com')
    if old_admin
      old_admin.destroy
      puts "✓ Deleted old admin: admin@nachinacon.com"
